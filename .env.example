# Copy this file to .env and fill in what you need.
# Everything has a sensible default — you can run the app with an EMPTY .env.

# --- Answer-generation LLM (OPTIONAL) --------------------------------------
# If no key is set, the chatbot still works: it returns the best-matching
# knowledge-base content directly (extractive answers) and uses the most
# representative user question as each FAQ entry. The ENTIRE semantic-FAQ engine
# needs no LLM. Add a key only for polished, generated answers.

# Provider: gemini | openrouter | anthropic | none
LLM_PROVIDER=openrouter

# --- Google Gemini (recommended free option) -------------------------------
# Free API key (real free tier, reliable limits) from:
#   https://aistudio.google.com/apikey
# To use it: set LLM_PROVIDER=gemini and paste the key below.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- OpenRouter (free open-source models, but heavily rate-limited) ---------
# Get a free key at https://openrouter.ai/keys . Pick any ":free" model from
# https://openrouter.ai/models?max_price=0 — free models cost $0.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Anthropic (only if LLM_PROVIDER=anthropic) ----------------------------
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# --- Semantic frequency engine (tunable) -----------------------------------
# Cosine similarity threshold for the real-time grouping step. Tuned for the
# default all-MiniLM-L6-v2 embeddings (~0.45 collapses paraphrases into one
# cluster while keeping distinct intents apart). Higher = stricter (more,
# tighter clusters); lower = looser (risk of merging different intents).
SIM_THRESHOLD=0.45

# How many FAQ entries to surface.
FAQ_TOP_N=8

# Rank FAQ by how often each question was asked within this trailing window
# (so "currently trending" questions rise). Set to 0 to rank by all-time count.
RECENCY_WINDOW_DAYS=30

# A cluster must reach this many asks before we spend an LLM call to generate a
# clean canonical question + answer for it.
CANONICAL_MIN_COUNT=3

# --- Retrieval -------------------------------------------------------------
RAG_TOP_K=4

# Below this top-chunk similarity, a message is treated as a greeting / small
# talk / off-topic and gets a friendly reply instead of a forced FAQ answer.
RELEVANCE_THRESHOLD=0.25

# Hybrid retrieval (vector + BM25) fusion constant.
RRF_K=60

# --- Answer cache (cuts LLM calls + dodges rate limits) --------------------
ENABLE_ANSWER_CACHE=true
CACHE_SIM_THRESHOLD=0.93

# --- Follow-up query rewriting (1 extra LLM call, only on follow-ups) -------
ENABLE_QUERY_REWRITE=true

# --- Storage backend -------------------------------------------------------
# "sqlite" (default, local file) or "mongodb" (persistent — e.g. Atlas free tier,
# survives Hugging Face Space rebuilds).
STORE_BACKEND=sqlite
# For STORE_BACKEND=mongodb: your Atlas connection string + database name.
#   MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=faqbot

# --- Models / paths (rarely changed) ---------------------------------------
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
DB_PATH=data/faq.db
